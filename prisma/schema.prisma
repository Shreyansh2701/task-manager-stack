generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  avatar        String?
  passwordHash  String?
  provider      String    @default("credentials") // credentials | google | github
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  workspaceMemberships WorkspaceMember[]
  ownedWorkspaces      Workspace[]       @relation("WorkspaceOwner")
  comments             Comment[]
  timeEntries          TimeEntry[]
  notifications        Notification[]
  activityLogs         ActivityLog[]
  taskAssignments      TaskAssignee[]

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  @@map("users")
}

// ─── NextAuth Models ─────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Workspaces ──────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner        User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members      WorkspaceMember[]
  projects     Project[]
  activityLogs ActivityLog[]
  invites      WorkspaceInvite[]

  @@map("workspaces")
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        Role     @default(MEMBER)
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("workspace_members")
}

model WorkspaceInvite {
  id          String   @id @default(cuid())
  workspaceId String
  email       String
  role        Role     @default(MEMBER)
  token       String   @unique @default(cuid())
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("workspace_invites")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

// ─── Projects ────────────────────────────────────────────

model Project {
  id          String        @id @default(cuid())
  workspaceId String
  name        String
  description String?       @db.Text
  defaultView ProjectView   @default(BOARD)
  status      ProjectStatus @default(ACTIVE)
  color       String        @default("#6366f1") // indigo
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sections  Section[]

  @@index([workspaceId])
  @@map("projects")
}

enum ProjectView {
  BOARD
  LIST
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
}

// ─── Sections (Kanban columns / List groups) ─────────────

model Section {
  id        String   @id @default(cuid())
  projectId String
  name      String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@index([projectId])
  @@map("sections")
}

// ─── Tasks ───────────────────────────────────────────────

model Task {
  id           String       @id @default(cuid())
  sectionId    String
  parentTaskId String?
  title        String
  description  String?      @db.Text
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(NONE)
  dueDate      DateTime?
  position     Int          @default(0)
  isArchived   Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  // Relations
  section     Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  parentTask  Task?          @relation("Subtasks", fields: [parentTaskId], references: [id], onDelete: Cascade)
  subtasks    Task[]         @relation("Subtasks")
  assignees   TaskAssignee[]
  comments    Comment[]
  attachments Attachment[]
  timeEntries TimeEntry[]

  @@index([sectionId])
  @@index([parentTaskId])
  @@map("tasks")
}

model TaskAssignee {
  id         String   @id @default(cuid())
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@map("task_assignees")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Comments ────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  userId    String
  content   String   @db.Text
  mentions  String[] // Array of user IDs mentioned
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("comments")
}

// ─── Attachments ─────────────────────────────────────────

model Attachment {
  id        String   @id @default(cuid())
  taskId    String
  fileName  String
  fileUrl   String
  fileSize  Int // bytes
  mimeType  String
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("attachments")
}

// ─── Time Entries ────────────────────────────────────────

model TimeEntry {
  id          String    @id @default(cuid())
  taskId      String
  userId      String
  description String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int? // seconds
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@map("time_entries")
}

// ─── Notifications ───────────────────────────────────────

model Notification {
  id         String           @id @default(cuid())
  userId     String
  type       NotificationType
  title      String
  message    String?
  entityType String? // "task" | "project" | "comment" | "workspace"
  entityId   String?
  read       Boolean          @default(false)
  createdAt  DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  TASK_DUE_SOON
  COMMENT_ADDED
  MENTIONED
  MEMBER_JOINED
  INVITE_RECEIVED
}

// ─── Activity Log ────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  action      String // "created" | "updated" | "deleted" | "moved" | "archived"
  entityType  String // "task" | "project" | "section" | "comment"
  entityId    String
  metadata    Json?  // Additional context (e.g., { from: "Todo", to: "Done" })
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@map("activity_logs")
}
